{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Yarp": "Debug"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "institution-route": {
        "ClusterId": "institution-cluster",
        "Match": {
          "Path": "/api/v1/institutions/{**catch-all}"
        }
      },
      "facility-route": {
        "ClusterId": "facility-cluster",
        "Match": {
          "Path": "/api/v1/facilities/{**catch-all}"
        }
      },
      "scheduling-route": {
        "ClusterId": "scheduling-cluster",
        "Match": {
          "Path": "/api/v1/scheduling/{**catch-all}"
        }
      },
      "serviceworkflow-route": {
        "ClusterId": "serviceworkflow-cluster",
        "Match": {
          "Path": "/api/v1/service-workflow/{**catch-all}"
        }
      },
      "projects-route": {
        "ClusterId": "projects-cluster",
        "Match": {
          "Path": "/api/v1/projects/{**catch-all}"
        }
      },
      "issues-route": {
        "ClusterId": "issues-cluster",
        "Match": {
          "Path": "/api/v1/issues/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-dest": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "institution-cluster": {
        "Destinations": {
          "institution-dest": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "facility-cluster": {
        "Destinations": {
          "facility-dest": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "scheduling-cluster": {
        "Destinations": {
          "scheduling-dest": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "serviceworkflow-cluster": {
        "Destinations": {
          "serviceworkflow-dest": {
            "Address": "http://localhost:5005/"
          }
        }
      },
      "projects-cluster": {
        "Destinations": {
          "projects-dest": {
            "Address": "http://localhost:5006/"
          }
        }
      },
      "issues-cluster": {
        "Destinations": {
          "issues-dest": {
            "Address": "http://localhost:5006/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-dest": {
            "Address": "http://localhost:5007/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}