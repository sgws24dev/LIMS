{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=ResearchLms_Identity;Integrated Security=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "ResearchLms",
    "Audience": "ResearchLms",
    "ExpiryInMinutes": 60
  },
  "RabbitMQ": {
    "Host": "localhost"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "DefaultIndex": "facilities"
  },
  "FileStorage": {
    "LocalPath": "uploads",
    "BaseUrl": "http://localhost:5003/uploads"
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/facility-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 104857600
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
