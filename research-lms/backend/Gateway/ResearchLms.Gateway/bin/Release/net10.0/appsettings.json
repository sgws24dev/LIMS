{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Yarp": "Debug"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "institution-route": {
        "ClusterId": "institution-cluster",
        "Match": {
          "Path": "/api/v1/institutions/{**catch-all}"
        }
      },
      "facility-route": {
        "ClusterId": "facility-cluster",
        "Match": {
          "Path": "/api/v1/facilities/{**catch-all}"
        }
      },
      "scheduling-route": {
        "ClusterId": "scheduling-cluster",
        "Match": {
          "Path": "/api/v1/scheduling/{**catch-all}"
        }
      },
      "serviceworkflow-route": {
        "ClusterId": "serviceworkflow-cluster",
        "Match": {
          "Path": "/api/v1/service-workflow/{**catch-all}"
        }
      },
      "projects-route": {
        "ClusterId": "projects-cluster",
        "Match": {
          "Path": "/api/v1/projects/{**catch-all}"
        }
      },
      "issues-route": {
        "ClusterId": "issues-cluster",
        "Match": {
          "Path": "/api/v1/issues/{**catch-all}"
        }
      },
      "aiservices-route": {
        "ClusterId": "aiservices-cluster",
        "Match": {
          "Path": "/api/v1/ai/{**catch-all}"
        }
      },
      "aiservices-mcp-route": {
        "ClusterId": "aiservices-cluster",
        "Match": {
          "Path": "/mcp/{**catch-all}"
        }
      },
      "aiservices-helpdesk-hub-route": {
        "ClusterId": "aiservices-cluster",
        "Match": {
          "Path": "/hubs/helpdesk/{**catch-all}"
        }
      },
      "aiservices-telemetry-hub-route": {
        "ClusterId": "aiservices-cluster",
        "Match": {
          "Path": "/hubs/telemetry/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },
      "billing-route": {
        "ClusterId": "billing-cluster",
        "Match": {
          "Path": "/api/v1/billing/{**catch-all}"
        }
      },
      "compliance-route": {
        "ClusterId": "compliance-cluster",
        "Match": {
          "Path": "/api/v1/compliance/{**catch-all}"
        }
      },
      "communications-route": {
        "ClusterId": "communications-cluster",
        "Match": {
          "Path": "/api/v1/communications/{**catch-all}"
        }
      },
      "communications-hub-route": {
        "ClusterId": "communications-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      },
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/v1/content/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-dest": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "institution-cluster": {
        "Destinations": {
