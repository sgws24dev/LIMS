{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Yarp": "Debug"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "institution-route": {
        "ClusterId": "institution-cluster",
        "Match": {
          "Path": "/api/v1/institutions/{**catch-all}"
        }
      },
      "facility-route": {
        "ClusterId": "facility-cluster",
        "Match": {
          "Path": "/api/v1/facilities/{**catch-all}"
        }
      },
      "scheduling-route": {
        "ClusterId": "scheduling-cluster",
        "Match": {
          "Path": "/api/v1/scheduling/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-dest": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "institution-cluster": {
        "Destinations": {
          "institution-dest": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "facility-cluster": {
        "Destinations": {
          "facility-dest": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "scheduling-cluster": {
        "Destinations": {
          "scheduling-dest": {
            "Address": "http://localhost:5004/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}